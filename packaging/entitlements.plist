<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Microphone access (paired with NSMicrophoneUsageDescription in the bundle). -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- PyInstaller bundles many unsigned .dylibs / .so files. The hardened
         runtime blocks loading these unless library validation is relaxed. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- CPython and native extensions (numpy, mlx, ctranslate2) rely on
         executable/writable memory pages the hardened runtime blocks by default. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
</dict>
</plist>
